{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "client-eight-roan-56.vercel.app"
        }
      ],
      "destination": "https://societysync.vercel.app/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/payments/:id/receipt", "destination": "/api/receipt-pdf?id=:id" },
    { "source": "/api/sheets/:path*", "destination": "/api/sheets?path=:path*" },
    { "source": "/api/ai/:path*", "destination": "/api/ai-chat?path=:path*" },
    { "source": "/api/ai-chat", "destination": "/api/ai-chat.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
