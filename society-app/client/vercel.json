{
  "build": {
    "env": {
      "VITE_API_URL": "https://society-backend-b004.onrender.com"
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "client-eight-roan-56.vercel.app"
        }
      ],
      "destination": "https://societysync-app.vercel.app/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/socket.io/:path*", "destination": "https://society-backend-b004.onrender.com/socket.io/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
