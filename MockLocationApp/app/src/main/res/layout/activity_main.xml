<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="#F8FAFC">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MOCK LOCATION PRO"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1E293B"
        android:layout_marginBottom="32dp" />

    <EditText
        android:id="@+id/etLat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Latitude (e.g. 28.6139)"
        android:inputType="numberDecimal|numberSigned"
        android:padding="16dp"
        android:background="@android:drawable/editbox_background"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etLong"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Longitude (e.g. 77.2090)"
        android:inputType="numberDecimal|numberSigned"
        android:padding="16dp"
        android:background="@android:drawable/editbox_background"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnPickMap"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="PICK ON MAP"
        android:backgroundTint="#64748B"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnStart"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="START MOCKING"
        android:backgroundTint="#0F172A"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnStop"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="STOP MOCKING"
        android:backgroundTint="#EF4444"
        android:textColor="#FFFFFF" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Note: Enable 'Mock Location App' in Developer Options first."
        android:textSize="12sp"
        android:textColor="#64748B"
        android:layout_marginTop="24dp"
        android:textAlignment="center" />

</LinearLayout>
